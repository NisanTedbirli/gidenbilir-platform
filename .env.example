# Giden Bilir — Docker Compose ortam değişkenleri
# Bu dosyayı .env olarak kopyala: cp .env.example .env

# Veritabanı şifresi (PostgreSQL)
DB_PASSWORD=changeme_in_production

# JWT imza anahtarı — min 32 karakter
JWT_SECRET=changeme_minimum_32_characters_long_here

# Cloudinary (fotoğraf yükleme)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
